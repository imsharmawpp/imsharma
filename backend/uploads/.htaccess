# Allow file access but prevent script execution
Options -ExecCGI -Indexes
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8
RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8

<FilesMatch "\.(php|phtml|phps|php3|php4|php5|php7|php8|cgi|pl|py|jsp|asp|sh|exe|html?)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Allow images and PDFs
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|pdf)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>
